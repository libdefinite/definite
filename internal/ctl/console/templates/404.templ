package templates

templ NotFound() {
	@Layout("404 – Not Found") {
		<main class="min-h-screen bg-gray-50 flex items-center justify-center">
			<div class="text-center">
				<p class="text-6xl font-bold text-gray-900">404</p>
				<p class="mt-4 text-gray-500">Page not found.</p>
			</div>
		</main>
	}
}
