{
    "name": "Definite",
    "image": "mcr.microsoft.com/devcontainers/go:1.26",
    "features": {
        "ghcr.io/devcontainers/features/node:1": { "version": "22" },
        "ghcr.io/devcontainers-extra/features/tmux-apt-get:1": {},
        "ghcr.io/devcontainers/features/docker-in-docker:2": { "moby": false }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "bufbuild.vscode-buf",
                "skellock.just",
                "redhat.vscode-yaml"
            ],
            "settings": {
                "go.toolsManagement.checkForUpdates": "local",
                "go.useLanguageServer": true,
                "buf.binaryPath": "/usr/local/bin/buf"
            }
        }
    },
    "postCreateCommand": {
        "tmux": "cp .devcontainer/tmux.conf ~/.tmux.conf && git clone --depth 1 https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm",
        "npm": "npm install -g markdownlint-cli prettier @bufbuild/buf rust-just && npm install",
        "go": "go mod download && go tool lefthook install && go install github.com/air-verse/air@latest"
    }
}
